# ─── Site Configuration ───────────────────────────────────────
# Required: Set to your production URL when deploying
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Google Search Console ────────────────────────────────────
# Required for Google Search indexing verification
# Get your code at https://search.google.com/search-console
NEXT_PUBLIC_GOOGLE_VERIFICATION=

# ─── Google Analytics (GA4) ───────────────────────────────────
# Optional. Set your Measurement ID to enable analytics.
# Format: G-XXXXXXXXXX
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ─── Google AdSense ───────────────────────────────────────────
# Optional. Set these to serve real ads.
# NEXT_PUBLIC_ADSENSE_PUBLISHER_ID=ca-pub-XXXXXXXXXXXXXXXX
# NEXT_PUBLIC_ADSENSE_SLOT_BANNER_TOP=XXXXXXXXXX
# NEXT_PUBLIC_ADSENSE_SLOT_IN_CONTENT=XXXXXXXXXX
# NEXT_PUBLIC_ADSENSE_SLOT_SIDEBAR=XXXXXXXXXX
# NEXT_PUBLIC_ADSENSE_SLOT_FOOTER=XXXXXXXXXX
# NEXT_PUBLIC_ADSENSE_SLOT_MOBILE_STICKY=XXXXXXXXXX

# ─── Contact Form ─────────────────────────────────────────────
# Optional. URL to POST contact form submissions.
# NEXT_PUBLIC_CONTACT_FORM_URL=https://your-form-endpoint.com/api

# ─── Affiliate Referral Codes ─────────────────────────────────
# Optional. Set to enable money transfer affiliate links.
# NEXT_PUBLIC_WISE_REFERRAL=
# NEXT_PUBLIC_REVOLUT_REFERRAL=
# NEXT_PUBLIC_CURRENCYFAIR_REFERRAL=

# ─── Exchange Rate API ────────────────────────────────────────
# Optional. Frankfurter (free, no key) is the default.
# For production, consider ExchangeRate-API for broader coverage:
# NEXT_PUBLIC_EXCHANGE_RATE_PROVIDER=exchangerate-api
# EXCHANGE_RATE_API_KEY=your-api-key-here
